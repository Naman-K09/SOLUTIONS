#include <bits/stdc++.h>
using namespace std;

#define ll long long
#define fast_io ios_base::sync_with_stdio(false); cin.tie(NULL);
#define error cout << "Hare Krishna" << endl;

double ispossible(vector<int>& arr, double& mid, int& n) {
    double count = 0;

    for(int i = 0; i < n - 1; i++) {
        double needed = (arr[i+1] - arr[i]) / mid;

        if(fmod((arr[i+1] - arr[i]),mid) == 0) needed--;

        count += needed;
    }

    return count;
}

long double minimiseMaxDistance(vector<int>& arr, int k) {
    int n = arr.size();
    
    int low = 0;
    int high = 1e6;
    for(int i = 0; i < 100; i++) {
        double mid = (low + high) / 2.0;

        int minstation = ispossible(arr, mid, n);
        
        if(minstation > k) {
            high = mid;
        }
        else low = mid;
    }

    return high;
}

int main() {
    fast_io;
    int k, n;
    cin >> k >> n;
    vector<int> arr(n);
    for(int i = 0; i < n; i++) cin >> arr[i];

    cout << minimiseMaxDistance(arr, k) <<endl;
    return 0;
}






























